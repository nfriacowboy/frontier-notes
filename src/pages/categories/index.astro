---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const base = import.meta.env.BASE_URL;
const allPosts = await getCollection('posts', ({ data }) => !data.draft);

const categories = [...new Set(allPosts.map((p) => p.data.category))].sort();
const categoryCount = Object.fromEntries(
  categories.map((cat) => [cat, allPosts.filter((p) => p.data.category === cat).length])
);
---

<Base title="Categories">
  <div class="page-header">
    <div class="container">
      <h1>Categories</h1>
    </div>
  </div>

  <div class="container">
    <div class="categories-grid">
      {categories.map((category) => (
        <a
          href={`${base}/categories/${category.toLowerCase().replace(/\s+/g, '-')}`}
          class="category-card"
        >
          <h2>{category}</h2>
          <span class="count">{categoryCount[category]} post{categoryCount[category] !== 1 ? 's' : ''}</span>
        </a>
      ))}
    </div>
  </div>
</Base>
