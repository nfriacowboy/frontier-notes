---
import type { CollectionEntry } from 'astro:content';
import Base from './Base.astro';
import TagList from '../components/TagList.astro';
import References from '../components/References.astro';

export interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, subtitle, date, updated, author, excerpt, category, tags, image, imageAlt, aiDisclosure, references } = post.data;

const base = import.meta.env.BASE_URL;
const formattedDate = date.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' });
const formattedUpdated = updated?.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' });
const imageUrl = image ? `${base}${image}` : undefined;
---

<Base
  title={title}
  description={excerpt}
  image={imageUrl}
  type="article"
>
  <article class="post">
    <header class="post-header">
      <div class="container">
        <div class="post-meta-top">
          <a href={`${base}/categories/${category.toLowerCase().replace(/\s+/g, '-')}`} class="category-badge">
            {category}
          </a>
        </div>
        <h1 class="post-title">{title}</h1>
        {subtitle && <p class="post-subtitle">{subtitle}</p>}
        <p class="post-excerpt">{excerpt}</p>
        <div class="post-meta">
          <span>By <strong>{author}</strong></span>
          <span>&mdash;</span>
          <time datetime={date.toISOString()}>{formattedDate}</time>
          {updated && (
            <span class="updated-note">
              (updated <time datetime={updated.toISOString()}>{formattedUpdated}</time>)
            </span>
          )}
        </div>
        {tags && tags.length > 0 && <TagList tags={tags} base={base} />}
      </div>
    </header>

    {image && (
      <div class="post-image container">
        <img src={imageUrl} alt={imageAlt ?? title} width="1200" height="630" loading="eager" />
      </div>
    )}

    {aiDisclosure && (
      <div class="ai-disclosure container">
        <span class="ai-disclosure-icon">🤖</span>
        Article enhanced by AI and always reviewed and verified by the human.
      </div>
    )}

    <div class="post-content container">
      <slot />
    </div>

    {references && references.length > 0 && (
      <aside class="post-references container">
        <References references={references} />
      </aside>
    )}

    <footer class="post-footer container">
      <a href={`${base}/blog`} class="back-link">&larr; All posts</a>
    </footer>
  </article>
</Base>
