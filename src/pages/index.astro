---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import PostCard from '../components/PostCard.astro';

const base = import.meta.env.BASE_URL;
const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const recentPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);
---

<Base title="Frontier Notes">
  <section class="hero">
    <div class="container">
      <p class="hero-eyebrow">frontier notes</p>
      <h1>Thinking out loud<br />on AI, trust, and security.</h1>
      <p>Research, governance, and the hard problems at the intersection of artificial intelligence and cybersecurity.</p>
    </div>
  </section>

  <section class="posts-grid">
    <div class="container">
      <ul class="posts-list">
        {recentPosts.map((post) => (
          <li>
            <PostCard post={post} base={base} />
          </li>
        ))}
      </ul>
      {allPosts.length > 5 && (
        <div style="text-align: center; margin-top: 2rem;">
          <a href={`${base}/blog`} class="back-link">All posts &rarr;</a>
        </div>
      )}
    </div>
  </section>
</Base>
